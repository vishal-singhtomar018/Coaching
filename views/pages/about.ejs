<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- HERO -->
<section class="pt-32 pb-20 bg-[#f8f7f5] overflow-hidden">

    <div class="max-w-7xl mx-auto px-6 lg:px-8">

        <div class="grid lg:grid-cols-2 gap-14 items-center">

            <!-- Content -->
            <div data-aos="fade-right">

                <p class="uppercase tracking-[4px] text-[#c9a15f] text-sm mb-4">
                    About The Tutor
                </p>

                <h1 class="font-serif text-5xl lg:text-7xl leading-tight mb-8">
                    Meet
                    <span class="italic text-[#c9a15f]">
                        Mr. Ankit
                    </span>
                </h1>

                <p class="text-gray-600 leading-8 mb-6">
                    After completing an M.Sc. in Mathematics and earning a Gold Medal
                    in B.Ed., I spent years in institutional teaching before realizing
                    that every student learns differently.
                </p>

                <p class="text-gray-600 leading-8 mb-10">
                    In 2012, Architectural Academy was founded with one belief:
                    personalized teaching unlocks potential that crowded classrooms
                    often miss. Today, more than 500 students have benefited from
                    this approach.
                </p>

                <div class="grid sm:grid-cols-3 gap-6">

                    <div class="border-l-2 border-[#c9a15f] pl-4">
                        <h4 class="font-semibold">
                            M.Sc Mathematics
                        </h4>
                        <p class="text-sm text-gray-500">
                            Delhi University
                        </p>
                    </div>

                    <div class="border-l-2 border-[#c9a15f] pl-4">
                        <h4 class="font-semibold">
                            Gold Medalist
                        </h4>
                        <p class="text-sm text-gray-500">
                            B.Ed Certified
                        </p>
                    </div>

                    <div class="border-l-2 border-[#c9a15f] pl-4">
                        <h4 class="font-semibold">
                            12+ Years
                        </h4>
                        <p class="text-sm text-gray-500">
                            Teaching Experience
                        </p>
                    </div>

                </div>

            </div>

            <!-- Image -->
            <div
                class="relative"
                data-aos="fade-left"
                data-aos-delay="300">

                <div
                    class="absolute -top-4 -left-4 w-16 h-16 border-t border-l border-[#c9a15f]">
                </div>

                <div
                    class="absolute -bottom-4 -right-4 w-16 h-16 border-b border-r border-[#c9a15f]">
                </div>

                <div class="floating-image overflow-hidden">

                    <img
                        src="/images/teacher.jpg"
                        alt="Tutor"
                        class="w-full h-[650px] object-cover shadow-xl">

                </div>

            </div>

        </div>

    </div>

</section>

<!-- PHILOSOPHY -->
<section class="py-24 bg-black text-white">

    <div class="max-w-7xl mx-auto px-6">

        <p class="uppercase tracking-[4px] text-[#c9a15f] text-sm mb-4">
            Teaching Philosophy
        </p>

        <h2 class="font-serif text-5xl mb-16">
            How We Teach
        </h2>

        <div class="grid md:grid-cols-2 gap-8">

            <div
                class="border border-white/10 p-8"
                data-aos="fade-up">

                <h3 class="font-serif text-2xl mb-3">
                    Structure Before Speed
                </h3>

                <p class="text-gray-400 leading-7">
                    Strong foundations create lasting results. We focus on
                    understanding before acceleration.
                </p>

            </div>

            <div
                class="border border-white/10 p-8"
                data-aos="fade-up"
                data-aos-delay="100">

                <h3 class="font-serif text-2xl mb-3">
                    Individual Attention
                </h3>

                <p class="text-gray-400 leading-7">
                    Every student's doubts are addressed through personalized
                    guidance and mentoring.
                </p>

            </div>

            <div
                class="border border-white/10 p-8"
                data-aos="fade-up"
                data-aos-delay="200">

                <h3 class="font-serif text-2xl mb-3">
                    Concept Based Learning
                </h3>

                <p class="text-gray-400 leading-7">
                    Memorization fades. Understanding remains. We teach concepts,
                    not shortcuts.
                </p>

            </div>

            <div
                class="border border-white/10 p-8"
                data-aos="fade-up"
                data-aos-delay="300">

                <h3 class="font-serif text-2xl mb-3">
                    Continuous Assessment
                </h3>

                <p class="text-gray-400 leading-7">
                    Weekly tests and progress tracking ensure measurable growth.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- JOURNEY -->
<section class="py-24 bg-white">

    <div class="max-w-4xl mx-auto px-6">

        <div class="text-center mb-16">

            <p class="uppercase tracking-[4px] text-[#c9a15f] text-sm mb-4">
                Our Journey
            </p>

            <h2 class="font-serif text-5xl">
                The Story So Far
            </h2>

        </div>

        <div class="relative">

            <div class="absolute left-4 top-0 bottom-0 w-px bg-gray-300"></div>

            <div class="space-y-12">

                <div class="relative pl-14" data-aos="fade-right">
                    <div
                        class="absolute left-0 top-2 w-8 h-8 rounded-full bg-[#c9a15f]">
                    </div>

                    <h4 class="text-[#c9a15f] font-semibold mb-2">
                        2012
                    </h4>

                    <p class="text-gray-600">
                        Started private tutoring with only 3 students.
                    </p>
                </div>

                <div class="relative pl-14" data-aos="fade-right">
                    <div
                        class="absolute left-0 top-2 w-8 h-8 rounded-full bg-[#c9a15f]">
                    </div>

                    <h4 class="text-[#c9a15f] font-semibold mb-2">
                        2015
                    </h4>

                    <p class="text-gray-600">
                        Expanded into structured coaching batches.
                    </p>
                </div>

                <div class="relative pl-14" data-aos="fade-right">
                    <div
                        class="absolute left-0 top-2 w-8 h-8 rounded-full bg-[#c9a15f]">
                    </div>

                    <h4 class="text-[#c9a15f] font-semibold mb-2">
                        2018
                    </h4>

                    <p class="text-gray-600">
                        Achieved 100+ student milestone.
                    </p>
                </div>

                <div class="relative pl-14" data-aos="fade-right">
                    <div
                        class="absolute left-0 top-2 w-8 h-8 rounded-full bg-[#c9a15f]">
                    </div>

                    <h4 class="text-[#c9a15f] font-semibold mb-2">
                        2020
                    </h4>

                    <p class="text-gray-600">
                        Introduced online and hybrid classes.
                    </p>
                </div>

                <div class="relative pl-14" data-aos="fade-right">
                    <div
                        class="absolute left-0 top-2 w-8 h-8 rounded-full bg-[#c9a15f]">
                    </div>

                    <h4 class="text-[#c9a15f] font-semibold mb-2">
                        2024
                    </h4>

                    <p class="text-gray-600">
                        500+ students taught successfully.
                    </p>
                </div>

            </div>

        </div>

    </div>

</section>

<!-- CTA -->
<section class="py-24 bg-[#f8f7f5]">

    <div class="max-w-4xl mx-auto text-center px-6">

        <h2 class="font-serif text-5xl mb-6">
            Become Part Of Our Story
        </h2>

        <p class="text-gray-600 mb-10">
            Join hundreds of students who have transformed their academic
            journey through structured learning.
        </p>

        <a
            href="/enroll-tutor"
            class="inline-block bg-black text-white px-10 py-4 hover:bg-[#c9a15f] hover:text-black transition">

            Become part of Our Story →

        </a>

    </div>

</section>

