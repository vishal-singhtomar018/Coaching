<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<section class="bg-[#f8f7f5] min-h-screen pt-32 pb-20">

    <div class="max-w-7xl mx-auto px-6">

        <!-- Header -->
        <div class="flex flex-col md:flex-row md:justify-between md:items-center mb-12">

            <div>
                <h1 class="font-serif text-5xl mb-2">
                    Admin Dashboard 👨‍💼
                </h1>

                <p class="text-gray-500">
                    Welcome back! Here's an overview of your coaching institute.
                </p>
            </div>

            <div class="mt-6 md:mt-0">
                <span class="bg-[#c9a15f] text-black px-5 py-2 rounded-full font-medium">
                    Administrator
                </span>
            </div>

        </div>

        <!-- Statistics -->
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-8 mb-16">

            <!-- Students -->
            <div class="bg-white rounded-xl shadow-md p-8 border-l-4 border-blue-500">

                <div class="flex justify-between items-center">

                    <div>

                        <h2 class="text-5xl font-serif text-blue-600">
                            <%= students.length %>
                        </h2>

                        <p class="mt-3 text-gray-500">
                            Students
                        </p>

                    </div>

                    <i class="fa-solid fa-user-graduate text-5xl text-blue-200"></i>

                </div>

            </div>

            <!-- Approved Tutors -->
            <div class="bg-white rounded-xl shadow-md p-8 border-l-4 border-green-500">

                <div class="flex justify-between items-center">

                    <div>

                        <h2 class="text-5xl font-serif text-green-600">
                            <%= approvedTutors.length %>
                        </h2>

                        <p class="mt-3 text-gray-500">
                            Approved Tutors
                        </p>

                    </div>

                    <i class="fa-solid fa-chalkboard-user text-5xl text-green-200"></i>

                </div>

            </div>

            <!-- Pending Tutors -->
            <div class="bg-white rounded-xl shadow-md p-8 border-l-4 border-yellow-500">

                <div class="flex justify-between items-center">

                    <div>

                        <h2 class="text-5xl font-serif text-yellow-500">
                            <%= pendingTutors.length %>
                        </h2>

                        <p class="mt-3 text-gray-500">
                            Pending Tutors
                        </p>

                    </div>

                    <i class="fa-solid fa-hourglass-half text-5xl text-yellow-200"></i>

                </div>

            </div>

            <!-- Messages -->
            <div class="bg-white rounded-xl shadow-md p-8 border-l-4 border-red-500">

                <div class="flex justify-between items-center">

                    <div>

                        <h2 class="text-5xl font-serif text-red-500">
                            <%= messages.length %>
                        </h2>

                        <p class="mt-3 text-gray-500">
                            Messages
                        </p>

                    </div>

                    <i class="fa-solid fa-envelope text-5xl text-red-200"></i>

                </div>

            </div>

        </div>

        <!-- Quick Actions -->
        <div class="bg-white rounded-xl shadow-md p-10">

            <h2 class="font-serif text-3xl mb-8">
                Quick Actions
            </h2>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

                <a href="/admin/students"
                    class="bg-black text-white rounded-xl p-8 text-center hover:bg-[#c9a15f] hover:text-black transition">

                    <i class="fa-solid fa-user-graduate text-4xl mb-4"></i>

                    <h3 class="text-xl font-semibold">
                        Students
                    </h3>

                    <p class="mt-2 text-sm opacity-80">
                        View & Manage Students
                    </p>

                </a>

                <a href="/admin/pending-tutors"
                    class="bg-yellow-500 text-white rounded-xl p-8 text-center hover:bg-yellow-600 transition">

                    <i class="fa-solid fa-user-clock text-4xl mb-4"></i>

                    <h3 class="text-xl font-semibold">
                        Pending Tutors
                    </h3>

                    <p class="mt-2 text-sm">
                        Approve / Reject Requests
                    </p>

                </a>

                <a href="/admin/tutors"
                    class="bg-green-600 text-white rounded-xl p-8 text-center hover:bg-green-700 transition">

                    <i class="fa-solid fa-chalkboard-user text-4xl mb-4"></i>

                    <h3 class="text-xl font-semibold">
                        Approved Tutors
                    </h3>

                    <p class="mt-2 text-sm">
                        Manage Tutor Accounts
                    </p>

                </a>

                <a href="/admin/messages"
                    class="bg-blue-600 text-white rounded-xl p-8 text-center hover:bg-blue-700 transition">

                    <i class="fa-solid fa-envelope text-4xl mb-4"></i>

                    <h3 class="text-xl font-semibold">
                        Messages
                    </h3>

                    <p class="mt-2 text-sm">
                        Contact & Enquiries
                    </p>

                </a>

            </div>

        </div>

    </div>

</section>

<%- include('../partials/footer') %>