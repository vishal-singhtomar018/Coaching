<%- include('../partials/head') %>

    <%- include('../partials/navbar') %>
       <section class="max-w-7xl mx-auto px-6 py-16 min-h-[calc(100vh-80px)]">

            <h1 class="font-serif text-3xl md:text-5xl mb-8 md:mb-10">
                Student Enrollments
            </h1>

            <% if (students.length===0) { %>

                <p class="text-gray-500">
                    No students enrolled yet.
                </p>

                <% } else { %>

                    <div class="flex justify-center my-10">

                        <form action="/admin/students/search" method="GET"
                            class="flex items-center bg-white border border-gray-300 rounded-full shadow-md overflow-hidden w-full max-w-xl">

                            <span class="pl-5 text-gray-500">
                                <i class="fa-solid fa-magnifying-glass"></i>
                            </span>

                            <input type="text" name="q" placeholder="Search Student"
                                class="flex-1 px-4 py-3 outline-none text-gray-700 placeholder-gray-400">

                            <button type="submit"
                                class="bg-black hover:bg-[#c9a15f] hover:text-black text-white px-6 py-3 transition duration-300">

                                Search

                            </button>

                        </form>

                    </div>
                    <div class="overflow-x-auto rounded-lg border shadow bg-white">

                        <table class="min-w-[700px] w-full">

                            <thead class="bg-black text-white">

                                <tr>

                                    <th class="p-3 md:p-4 text-left whitespace-nowrap">
                                        Name
                                    </th>

                                    <th class="p-3 md:p-4 text-left whitespace-nowrap">
                                        Email
                                    </th>

                                    <th class="p-3 md:p-4 text-left whitespace-nowrap">
                                        Phone
                                    </th>

                                    <th class="p-3 md:p-4 text-left whitespace-nowrap">
                                        Class
                                    </th>

                                    <th class="p-3 md:p-4 text-center whitespace-nowrap">
                                        Action
                                    </th>

                                </tr>

                            </thead>

                            <tbody>

                                <% students.forEach(student=> { %>

                                    <tr class="border-b hover:bg-gray-50 transition">

                                        <td class="p-3 md:p-4 whitespace-nowrap">
                                            <%= student.studentName %>
                                        </td>

                                        <td class="p-3 md:p-4 whitespace-nowrap text-sm">
                                            <%= student.email %>
                                        </td>

                                        <td class="p-3 md:p-4 whitespace-nowrap">
                                            <%= student.studentContact %>
                                        </td>

                                        <td class="p-3 md:p-4 whitespace-nowrap">
                                            <%= student.class %>
                                        </td>

                                        <td class="p-3 md:p-4 text-center">

                                            <form action="/admin/students/<%= student._id %>/delete" method="POST"
                                                onsubmit="return confirm('Delete this student?')">

                                                <button class="text-red-600 hover:text-red-800 text-lg">

                                                    <i class="fa-solid fa-trash"></i>

                                                </button>

                                            </form>

                                        </td>

                                    </tr>

                                    <% }) %>

                            </tbody>

                        </table>

                    </div>

                    <% } %>

        </section>

        <%- include('../partials/footer') %>