<%- include('../partials/head') %>
    <%- include('../partials/navbar') %>

        <section class="max-w-7xl mx-auto px-6 py-16 min-h-screen">

            <h1 class="text-5xl font-serif mb-3">
                Welcome,
                <%= student.studentName %> 👋
            </h1>

            <p class="text-gray-500 mb-10">
                Student Dashboard
            </p>

            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">

                <!-- Assigned Tutor Card -->

                <div class="bg-white shadow rounded-lg p-6 mt-8">

                    <h2 class="text-2xl font-serif mb-4">
                        Assigned Tutor
                    </h2>

                    <% if(student.assignedTutor){ %>

                        <div class="space-y-2">

                            <p>
                                <strong>Name:</strong>
                                <%= student.assignedTutor.name %>
                            </p>

                            <p>
                                <strong>Subject:</strong>
                                <%= student.assignedTutor.subjectExpertise %>
                            </p>

                            <p>
                                <strong>Experience:</strong>
                                <%= student.assignedTutor.experience %>
                            </p>

                            <p>
                                <strong>Contact:</strong>
                                <%= student.assignedTutor.contactNumber %>
                            </p>

                        </div>

                        <% } else { %>

                            <div class="bg-yellow-50 border border-yellow-300 p-4 rounded">

                                <p class="text-yellow-700">

                                    No tutor has been assigned yet.

                                </p>

                            </div>

                            <% } %>

                </div>

                <div class="border rounded-lg p-6 bg-white shadow">
                    <h2 class="text-lg font-semibold">
                        Attendance
                    </h2>

                    <p class="text-3xl mt-3">
                        --
                    </p>
                </div>

                <div class="border rounded-lg p-6 bg-white shadow">
                    <h2 class="text-lg font-semibold">
                        Assignments
                    </h2>

                    <p class="text-3xl mt-3">
                        0
                    </p>
                </div>

                <div class="border rounded-lg p-6 bg-white shadow">
                    <h2 class="text-lg font-semibold">
                        Study Materials
                    </h2>

                    <p class="text-3xl mt-3">
                        0
                    </p>
                </div>

            </div>

        </section>

        <%- include('../partials/footer') %>