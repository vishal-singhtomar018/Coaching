<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<section class="max-w-7xl mx-auto px-6 py-16 min-h-[calc(100vh-80px)]">

    <h1 class="font-serif text-4xl mb-8">
        Student Search Results
    </h1>

    <% if (students.length === 0) { %>

        <div class="text-center py-20">

            <i class="fa-solid fa-user-graduate text-6xl text-gray-300 mb-4"></i>

            <h2 class="text-3xl font-serif text-gray-700 mb-2">
                No Student Found
            </h2>

            <p class="text-gray-500">
                No student matches your search.
            </p>

        </div>

    <% } else { %>

        <% students.forEach(student => { %>

            <div class="border rounded-lg shadow-sm p-5 mb-5 bg-white">

                <h3 class="text-xl font-semibold">
                    <%= student.studentName %>
                </h3>

                <p class="text-gray-600">
                    <%= student.email %>
                </p>

                <p class="text-gray-600">
                    <%= student.studentContact %>
                </p>

                <% if(student.isDeleted){ %>

                    <span class="inline-block mt-3 text-red-600 font-medium">
                        Inactive
                    </span>

                <% } else { %>

                    <span class="inline-block mt-3 text-green-600 font-medium">
                        Active
                    </span>

                <% } %>

            </div>

        <% }) %>

    <% } %>

</section>

<%- include('../partials/footer') %>