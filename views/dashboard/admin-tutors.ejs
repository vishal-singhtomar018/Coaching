<%- include('../partials/head') %>

    <%- include('../partials/navbar') %>
        <section class="max-w-7xl mx-auto py-16 px-6">

            <h1 class="font-serif text-5xl mb-10">
                Tutor Applications
            </h1>

            <% if (tutors.length===0) { %>

                <p class="text-gray-500">
                    No tutor applications yet.
                </p>

                <% } else { %>

                    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

                        <% tutors.forEach(tutor=> { %>

                            <div class="bg-white border shadow p-6">

                                <h3 class="font-serif text-3xl mb-2">
                                    <%= tutor.name %>
                                </h3>

                                <p class="text-gray-600 mb-3">
                                    <strong>Subject:</strong>
                                    <%= tutor.subjectExpertise %>
                                </p>

                                <p class="text-gray-600 mb-2">
                                    <strong>Email:</strong>
                                    <%= tutor.email %>
                                </p>

                                <p class="text-gray-600 mb-5">
                                    <strong>Phone:</strong>
                                    <%= tutor.contactNumber %>
                                </p>

                                <form action="/admin/tutors/<%= tutor._id %>/delete" method="POST"
                                    onsubmit="return confirm('Are you sure you want to delete this tutor?')">

                                    <button
                                        class="w-full bg-red-600 text-white py-3 rounded hover:bg-red-700 transition">

                                        <i class="fa-solid fa-trash mr-2"></i>
                                        Delete Tutor

                                    </button>

                                </form>

                            </div>

                            <% }) %>

                    </div>

                    <% } %>

        </section>

        <%- include('../partials/footer') %>