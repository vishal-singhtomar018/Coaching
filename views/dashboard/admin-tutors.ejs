<%- include('../partials/head') %>

    <%- include('../partials/navbar') %>
        <section class="max-w-7xl mx-auto px-6 py-16 min-h-[calc(100vh-80px)]">

            <h1 class="font-serif text-5xl mb-10">
                Tutor Applications
            </h1>
            <div class="flex justify-center my-10">

                <form action="/admin/tutors/search" method="GET"
                    class="flex items-center bg-white border border-gray-300 rounded-full shadow-md overflow-hidden w-full max-w-xl">

                    <span class="pl-5 text-gray-500">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </span>

                    <input type="text" name="q" placeholder="Search Tutor"
                        class="flex-1 px-4 py-3 outline-none text-gray-700 placeholder-gray-400">

                    <button type="submit"
                        class="bg-black hover:bg-[#c9a15f] hover:text-black text-white px-6 py-3 transition duration-300">

                        Search

                    </button>

                </form>
            </div>

            <% if (tutors.length===0) { %>

                <p class="text-gray-500">
                    No tutor applications yet.
                </p>
                <% } else { %>

                    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">

                        <% tutors.forEach(tutor=> { %>

                            <div class="bg-white border shadow p-6">

                                <h3 class="font-serif text-3xl mb-2">
                                    <%= tutor.name %>
                                </h3>

                                <p class="text-gray-600 mb-3">
                                    <strong>Subject:</strong>
                                    <%= tutor.subjectExpertise %>
                                </p>

                                <p class="text-gray-600 mb-2">
                                    <strong>Email:</strong>
                                    <%= tutor.email %>
                                </p>

                                <p class="text-gray-600 mb-5">
                                    <strong>Phone:</strong>
                                    <%= tutor.contactNumber %>
                                </p>

                                <td class="text-center ">

                                    <form action="/admin/tutors/<%= tutor._id %>/delete" method="POST"
                                        onsubmit="return confirm('Are you sure you want to delete this tutor?')">
                                        <button class="text-red-600 hover:text-red-800 text-lg">

                                            <i class="fa-solid fa-trash"></i>
                                            Remove

                                        </button>   

                                    </form>

                                </td>

                            </div>

                            <% }) %>

                    </div>

                    <% } %>

        </section>

        <%- include('../partials/footer') %>