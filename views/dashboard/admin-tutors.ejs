<%- include('../partials/head') %>
    <%- include('../partials/navbar') %>

        <section class="bg-[#f8f7f5] min-h-screen pt-32 pb-20">

            <div class="max-w-7xl mx-auto px-6">

                <div class="flex justify-between items-center mb-10">

                    <div>

                        <h1 class="font-serif text-5xl">
                            Approved Tutors
                        </h1>

                        <p class="text-gray-500 mt-2">
                            Manage all approved tutors.
                        </p>

                    </div>

                    <div class="bg-green-100 text-green-700 px-5 py-3 rounded-xl font-semibold">

                        Total :
                        <%= tutors.length %>

                    </div>

                </div>

                <!-- Search -->

                <div class="flex justify-center mb-14">

                    <form action="/admin/tutors/search" method="GET"
                        class="flex items-center bg-white rounded-full shadow-lg overflow-hidden border w-full max-w-2xl">

                        <span class="px-5 text-gray-500">

                            <i class="fa-solid fa-magnifying-glass"></i>

                        </span>

                        <input type="text" name="q" placeholder="Search tutor..." class="flex-1 py-4 outline-none">

                        <button class="bg-black text-white px-8 py-4 hover:bg-[#c9a15f] hover:text-black transition">

                            Search

                        </button>

                    </form>

                </div>

                <% if(tutors.length===0){ %>

                    <div class="flex justify-center items-center min-h-[45vh]">

                        <div class="bg-white shadow-lg rounded-2xl p-12 text-center w-full max-w-lg">

                            <i class="fa-solid fa-circle-check text-7xl text-green-500 mb-6"></i>

                            <h2 class="text-3xl font-serif mb-3">

                                No Approved Tutors

                            </h2>

                            <p class="text-gray-500">

                                Approved tutors will appear here.

                            </p>

                        </div>

                    </div>

                    <% } else { %>

                        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-8">

                            <% tutors.forEach(tutor=>{ %>

                                <div
                                    class="bg-white rounded-2xl shadow-lg hover:shadow-2xl transition duration-300 overflow-hidden">

                                    <!-- Header -->

                                    <div class="bg-[#c9a15f] p-6 text-white flex items-center justify-between">

                                        <div class="flex items-center gap-4">

                                            <div
                                                class="w-16 h-16 rounded-full bg-white text-[#c9a15f] flex items-center justify-center text-2xl font-bold">

                                                <%= tutor.name.charAt(0).toUpperCase() %>

                                            </div>

                                            <div>

                                                <h2 class="text-2xl font-semibold">

                                                    <%= tutor.name %>

                                                </h2>

                                                <p>

                                                    Tutor

                                                </p>

                                            </div>

                                        </div>

                                        <span
                                            class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-semibold">

                                            Approved

                                        </span>

                                    </div>

                                    <!-- Body -->

                                    <div class="p-6 space-y-4">

                                        <p>

                                            <i class="fa-solid fa-book text-[#c9a15f] mr-2"></i>

                                            <strong>Subject:</strong>

                                            <%= tutor.subjectExpertise %>

                                        </p>

                                        <p>

                                            <i class="fa-solid fa-graduation-cap text-[#c9a15f] mr-2"></i>

                                            <strong>Qualification:</strong>

                                            <%= tutor.qualification %>

                                        </p>

                                        <p>

                                            <i class="fa-solid fa-briefcase text-[#c9a15f] mr-2"></i>

                                            <strong>Experience:</strong>

                                            <%= tutor.experience %>

                                        </p>

                                        <p>

                                            <i class="fa-solid fa-envelope text-[#c9a15f] mr-2"></i>

                                            <%= tutor.email %>

                                        </p>

                                        <p>

                                            <i class="fa-solid fa-phone text-[#c9a15f] mr-2"></i>

                                            <%= tutor.contactNumber %>

                                        </p>

                                    </div>

                                    <!-- Footer -->

                                    <div class="border-t p-5">

                                        <form action="/admin/tutors/<%= tutor._id %>/delete" method="POST"
                                            onsubmit="return confirm('Delete this tutor?')">

                                            <button
                                                class="w-full bg-red-500 hover:bg-red-600 text-white py-3 rounded-xl transition">

                                                <i class="fa-solid fa-trash mr-2"></i>

                                                Remove Tutor

                                            </button>

                                        </form>

                                    </div>

                                </div>

                                <% }) %>

                        </div>

                        <% } %>

            </div>

        </section>

        <%- include('../partials/footer') %>