<%- include('../partials/head') %>
    <%- include('../partials/navbar') %>

        <section class="bg-[#f8f7f5] min-h-screen pt-32 pb-20">

            <div class="max-w-7xl mx-auto px-6">

                <!-- Heading -->

                <div class="flex flex-col md:flex-row md:justify-between md:items-center mb-10">

                    <div>

                        <h1 class="font-serif text-5xl">
                            Contact Messages
                        </h1>

                        <p class="text-gray-500 mt-2">
                            Review and manage all contact enquiries.
                        </p>

                    </div>

                    <div class="bg-[#c9a15f] text-white px-6 py-3 rounded-xl mt-6 md:mt-0">

                        <span class="font-semibold">

                            Total Messages :

                        </span>

                        <%= messages.length %>

                    </div>

                </div>

                <!-- Search -->

                <div class="flex justify-center mb-14">

                    <form action="/admin/messages/search" method="GET"
                        class="flex items-center bg-white rounded-full shadow-lg overflow-hidden border w-full max-w-2xl">

                        <span class="px-5 text-gray-500">

                            <i class="fa-solid fa-magnifying-glass"></i>

                        </span>

                        <input type="text" name="q" placeholder="Search message..." class="flex-1 py-4 outline-none">

                        <button class="bg-black text-white px-8 py-4 hover:bg-[#c9a15f] hover:text-black transition">

                            Search

                        </button>

                    </form>

                </div>

                <% if(messages.length===0){ %>

                    <div class="flex justify-center items-center min-h-[45vh]">

                        <div class="bg-white rounded-2xl shadow-lg p-12 text-center max-w-lg w-full">

                            <i class="fa-solid fa-envelope-open-text text-7xl text-[#c9a15f] mb-6"></i>

                            <h2 class="text-3xl font-serif mb-3">

                                No Messages Yet

                            </h2>

                            <p class="text-gray-500">

                                Contact enquiries will appear here.

                            </p>

                        </div>

                    </div>

                    <% } else { %>

                        <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-8">

                            <% messages.forEach(message=>{ %>

                                <div class="bg-white rounded-2xl shadow-lg hover:shadow-2xl transition overflow-hidden">

                                    <!-- Header -->

                                    <div class="bg-[#c9a15f] text-white p-6 flex justify-between items-center">

                                        <div class="flex items-center gap-4">

                                            <div
                                                class="w-16 h-16 rounded-full bg-white text-[#c9a15f] flex items-center justify-center text-2xl font-bold">

                                                <%= message.parentName.charAt(0).toUpperCase() %>

                                            </div>

                                            <div>

                                                <h2 class="text-2xl font-semibold">

                                                    <%= message.parentName %>

                                                </h2>

                                                <p>

                                                    Parent

                                                </p>

                                            </div>

                                        </div>

                                        <span class="bg-white text-[#c9a15f] px-3 py-1 rounded-full text-sm">

                                            New

                                        </span>

                                    </div>

                                    <!-- Body -->

                                    <div class="p-6 space-y-4">

                                        <p>

                                            <i class="fa-solid fa-envelope text-[#c9a15f] mr-2"></i>

                                            <%= message.email || "Not Provided" %>

                                        </p>

                                        <p>

                                            <i class="fa-solid fa-phone text-[#c9a15f] mr-2"></i>

                                            <%= message.phone %>

                                        </p>

                                        <div class="bg-gray-100 rounded-xl p-4">

                                            <p class="text-gray-700 leading-relaxed">

                                                <%= message.message %>

                                            </p>

                                        </div>

                                        <% if(message.createdAt){ %>

                                            <p class="text-sm text-gray-500">

                                                <i class="fa-solid fa-calendar mr-2"></i>

                                                <%= message.createdAt.toDateString() %>

                                            </p>

                                            <% } %>

                                    </div>

                                    <!-- Footer -->

                                    <div class="border-t p-5 flex gap-3">

                                        <form action="/admin/messages/<%= message._id %>/status" method="POST"
                                            class="flex-1">

                                            <select name="status" onchange="this.form.submit()"
                                                class="w-full border rounded-xl px-3 py-3">

                                                <option value="new" <%=message.status==='new' ? 'selected' : '' %>>

                                                    🟢 New

                                                </option>

                                                <option value="in-progress" <%=message.status==='in-progress'
                                                    ? 'selected' : '' %>>

                                                    🟡 In Progress

                                                </option>

                                                <option value="replied" <%=message.status==='replied' ? 'selected' : ''
                                                    %>>

                                                    🔵 Replied

                                                </option>

                                                <option value="closed" <%=message.status==='closed' ? 'selected' : '' %>
                                                    >

                                                    ⚪ Closed

                                                </option>

                                            </select>

                                        </form>
                                        <form action="/admin/messages/<%= message._id %>/delete" method="POST"
                                            class="flex-1" onsubmit="return confirm('Delete this message?')">

                                            <button
                                                class="w-full bg-red-500 hover:bg-red-600 text-white py-3 rounded-xl transition">

                                                <i class="fa-solid fa-trash mr-2"></i>

                                                Delete

                                            </button>

                                        </form>

                                    </div>

                                </div>

                                <% }) %>

                        </div>

                        <% } %>

            </div>

        </section>

        <%- include('../partials/footer') %>